rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return request.auth.token.email == 'tukukalandi@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidBill(data) {
      return data.keys().hasAll(['userId', 'bo', 'so', 'ho', 'month', 'year', 'dateString', 'entriesData', 'createdAt', 'updatedAt'])
        && (data.userId == request.auth.uid || isAdmin())
        && data.bo is string
        && data.so is string
        && data.ho is string
        && data.month is string
        && data.year is string
        && data.dateString is string
        && data.entriesData is string
        && data.createdAt is number
        && data.updatedAt is number
        && (!data.keys().hasAny(['status']) || data.status in ['Pending', 'Approved', 'Rejected', '']);
    }

    match /bills/{billId} {
      allow get: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(billId) 
        && isValidBill(incoming());
      allow update: if isSignedIn() && isValidBill(incoming()) && incoming().createdAt == existing().createdAt && (
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['bo', 'so', 'ho', 'month', 'year', 'dateString', 'entriesData', 'updatedAt', 'status'])) ||
        (existing().userId == request.auth.uid 
          && (!existing().keys().hasAny(['status']) || existing().status != 'Approved')
          && (!incoming().diff(existing()).affectedKeys().hasAny(['status']))
          && incoming().diff(existing()).affectedKeys().hasOnly(['bo', 'so', 'ho', 'month', 'year', 'dateString', 'entriesData', 'updatedAt'])
        )
      );
      allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
    }

    function isValidUserSettings(data) {
      return data.keys().hasAll(['userId'])
        && data.keys().size() <= 2
        && data.userId == request.auth.uid
        && (data.keys().hasAny(['spreadsheetId']) ? (data.spreadsheetId is string && data.spreadsheetId.size() <= 200) : true);
    }

    match /userSettings/{userId} {
      allow get: if isSignedIn() && userId == request.auth.uid;
      allow create: if isSignedIn() && userId == request.auth.uid
        && isValidUserSettings(incoming());
      allow update: if isSignedIn() && userId == request.auth.uid
        && existing().userId == request.auth.uid
        && isValidUserSettings(incoming())
        && incoming().userId == existing().userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['spreadsheetId']);
    }
  }
}
